  - triggerWhenHpPercentAtOrBelow: 0.35
    line: "Elle criait ton nom quand les cloches sont tomb\xE9es."
    voiceLine: {fileID: 0}
  deathDialogue: "Prends-le. Ce papier p\xE8se plus que ma cuirasse."
  deathVoiceLine: {fileID: 0}
  defeatResultText: "Il ajoute ton anneau absent \xE0 sa collection. L'emplacement
    \xE9tait d\xE9j\xE0 pr\xE9vu."
