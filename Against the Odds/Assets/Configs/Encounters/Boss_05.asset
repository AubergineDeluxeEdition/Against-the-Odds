  defaultAttackDamage: 10
  introDialogue: 'Te voilà enfin. Celui qui monte pour rendre aux hommes leur vieille
    lâcheté : la fin.'
  introVoiceLine: {fileID: 0}
  hpDialogues:
  - triggerWhenHpPercentAtOrBelow: 0.8
    line: Le Roi distribue le sang. Il ne crée pas l'obstination.
    voiceLine: {fileID: 0}
  - triggerWhenHpPercentAtOrBelow: 0.45
    line: Tu portes la clé dans la plaie et tu demandes qui a ouvert la porte.
    voiceLine: {fileID: 0}
  deathDialogue: Si tu réussis... ils t'appelleront libérateur. Ils ne sauront jamais
    ce que tu leur as repris.
  deathVoiceLine: {fileID: 0}
  defeatResultText: Il te bénit sans joie. Ton corps se relève avant que la prière
    soit terminée.
  victoryResultText: Le Cardinal n'adorait pas la douleur. Il adorait la continuité.
    Pour lui, ta quête n'était pas un salut, mais une profanation.
  bossDeathSfx: {fileID: 8300000, guid: fd318bafa5bd05040be0cf2bc5d86ab1, type: 3}
  victorySfx: {fileID: 8300000, guid: a5a4fc7157527324f9a1233dc68e70f7, type: 3}
