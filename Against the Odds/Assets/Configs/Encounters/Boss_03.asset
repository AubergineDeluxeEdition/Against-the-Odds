  defaultAttackDamage: 10
  introDialogue: Halte. Qui marche ? Un mort ? Un traître ? Un roi ?
  introVoiceLine: {fileID: 0}
  hpDialogues:
  - triggerWhenHpPercentAtOrBelow: 0.7
    line: Tu n'es pas celui d'hier... pourtant ton pas est le même.
    voiceLine: {fileID: 0}
  - triggerWhenHpPercentAtOrBelow: 0.35
    line: Je me souviens. Ce n'était pas l'ennemi devant les murs. C'était quelque
      chose dedans.
    voiceLine: {fileID: 0}
  deathDialogue: Je gardais la porte... contre toi ? Non... contre ton retour.
  deathVoiceLine: {fileID: 0}
  defeatResultText: Il plante sa lame dans ton ventre et salue ton cadavre comme
    un vieux camarade.
  victoryResultText: Il n'a jamais gardé Rhodesia contre les envahisseurs. Il gardait
    la ville contre la repetition.
