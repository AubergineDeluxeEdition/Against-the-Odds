  introDialogue: Tu es arrivé au cœur. C'est ce que tu crois.
  introVoiceLine: {fileID: 0}
  hpDialogues:
  - triggerWhenHpPercentAtOrBelow: 0.72
    line: Je pompe. Je redistribue. Je ne décide rien.
    voiceLine: {fileID: 0}
  - triggerWhenHpPercentAtOrBelow: 0.38
    line: Tu veux un coupable avec une couronne. C'est plus simple.
    voiceLine: {fileID: 0}
  deathDialogue: Je n'étais qu'une bouche. Le souffle venait d'ailleurs.
  deathVoiceLine: {fileID: 0}
  defeatResultText: La machine boit ton sang et le recrache dans la ville. Au loin,
    la fosse tousse déjà ton nom.
  victoryResultText: Le Roi tombe. Les pistons s'arrêtent. Puis, dans les rues, les
    morts remuent encore. Le cycle ne venait pas du trône. Il suivait celui qui refusait
    de finir.
