  hpDialogues:
  - triggerWhenHpPercentAtOrBelow: 0.75
    line: Tu hurlais plus fort la première fois.
    voiceLine: {fileID: 0}
  - triggerWhenHpPercentAtOrBelow: 0.45
    line: Je t'avais fermé les plaies. Qui t'a rendu à la route ?
    voiceLine: {fileID: 0}
  deathDialogue: Ton nom... je l'avais écrit avec les cas sans espoir.
  deathVoiceLine: {fileID: 0}
  defeatResultText: Il t'endort avec des gestes tendres. C'est presque pire que la
    violence.
  victoryResultText: Dans son registre, ton nom apparaît raturé. Il t'avait soigné
    avant que la ville ne te recrache dans la fosse.
