  - triggerWhenHpPercentAtOrBelow: 0.35
    line: Elle geint avant de mordre, comme si quelque chose en elle refusait encore.
    voiceLine: {fileID: 0}
  deathDialogue: Son dernier souffle ressemble presque à ton nom.
  deathVoiceLine: {fileID: 0}
  defeatResultText: Ses crocs se referment sur ta gorge. Quelque chose en elle pleure
