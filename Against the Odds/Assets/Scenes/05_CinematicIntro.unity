  m_Script: {fileID: 11500000, guid: e703158fc02f4a74bacfddda1a42d1fe, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AgainstTheOdds.Core.CinematicTimedTextSequence
  targetText: {fileID: 298124527}
  lines:
  - text: "Vous vous r\xE9veillez, comme si le monde vous avait \xE9cras\xE9."
    duration: 3
    startCreditsHere: 0
  - text: "Votre t\xEAte vous br\xFBle."
    duration: 3
    startCreditsHere: 0
  - text: "\"O\xF9 suis-je ?\""
    duration: 3
    startCreditsHere: 0
  - text: Dans une pile de cadavres.
    duration: 3
    startCreditsHere: 0
  - text: Une fosse.
    duration: 2
    startCreditsHere: 0
  - text: '"Qui suis-je ?"'
    duration: 3
    startCreditsHere: 0
  - text: "Votre main fr\xF4le une poign\xE9e reconnaissable."
    duration: 4
    startCreditsHere: 0
  - text: "\"Pourquoi me je r\xE9veille ?\""
    duration: 3
    startCreditsHere: 0
  - text: Plus de souvenirs.
    duration: 3
    startCreditsHere: 0
  - text: Un corps.
    duration: 3
    startCreditsHere: 0
  - text: "Qui vous appelle \xE0 vous relever encore."
    duration: 4
    startCreditsHere: 0
  - text: "Votre volont\xE9 sait."
    duration: 3
    startCreditsHere: 0
  - text: "Vous vous relevez en empoignant votre b\xE2ton."
    duration: 4
    startCreditsHere: 0
  - text: "Vous devez rejoindre cette forteresse \xE0 l'horizon."
    duration: 4
    startCreditsHere: 0
  - text: Encore une fois.
    duration: 3
    startCreditsHere: 0
  useUnscaledTime: 0
  startAfterSceneLoaderReveal: 1
  initialDelay: 3
  fadeInDuration: 0.35
  fadeOutDuration: 0.35
  clearTextWhenFinished: 1
  enableCredits: 0
  creditsText: {fileID: 298124527}
  creditsContent: 
